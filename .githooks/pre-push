#!/bin/bash
# Runs the TypeScript type check and the jest test suite before every push.
# Install once with: git config core.hooksPath .githooks

echo "Running TypeScript check..."
npx tsc --noEmit

if [ $? -ne 0 ]; then
  echo ""
  echo "Push blocked: TypeScript errors found above. Fix them before pushing."
  exit 1
fi

echo "TypeScript check passed."

echo "Running jest test suite..."
npm test --silent

if [ $? -ne 0 ]; then
  echo ""
  echo "Push blocked: test failures above. Fix them before pushing."
  exit 1
fi

echo "Tests passed."
