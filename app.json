{
  "expo": {
    "name": "Nyx",
    "slug": "project-nyx",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "nyx",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.projectnyx.app"
    },
    "android": {
      "package": "com.projectnyx.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "6928a16e-3d2e-4a2e-ac87-b6c20176430b"
      }
    },
    "owner": "project-nyx",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/6928a16e-3d2e-4a2e-ac87-b6c20176430b"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-router",
      "expo-font"
    ]
  }
}
