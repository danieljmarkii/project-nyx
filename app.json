{
  "expo": {
    "name": "Culprit",
    "slug": "project-nyx",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "nyx",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.projectnyx.app",
      "icon": {
        "light": "./assets/icon.png",
        "dark": "./assets/icon-dark.png",
        "tinted": "./assets/icon-tinted.png"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.projectnyx.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#13112E"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "6928a16e-3d2e-4a2e-ac87-b6c20176430b"
      }
    },
    "owner": "project-nyx",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/6928a16e-3d2e-4a2e-ac87-b6c20176430b"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Culprit uses your photo library so you can attach a saved photo of a meal, a symptom, a medication label, or your pet to a log or profile.",
          "cameraPermission": "Culprit uses the camera so you can take a photo of a meal, a symptom, a medication label, or your pet to add to a log or profile.",
          "microphonePermission": false
        }
      ],
      "expo-secure-store",
      "expo-sharing",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#13112E"
        }
      ],
      "expo-sqlite",
      "expo-status-bar"
    ]
  }
}
